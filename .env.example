# Netlify Functions environment variables
# Set these in Netlify UI with Functions scope.

# Optional: require this shared secret on browser -> function sync calls.
LEAD_SYNC_SECRET=

# Optional: require this shared secret on Vapi -> function webhook calls.
VAPI_WEBHOOK_SECRET=

# Optional: if assistant-request ever hits your webhook and you want a fallback assistant response.
VAPI_ASSISTANT_ID=230bdd16-e11a-413d-834b-7b1d07c26e19

# Google Sheets target
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=Leads!A:N

# Choose one of the following service-account formats:
# 1) full JSON blob
GOOGLE_SERVICE_ACCOUNT_JSON=

# 2) split fields
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

